graph LR
    subgraph P1["Phase 1: Teacher"]
        T1["MuJoCo Go1<br/>Ant-v5 env"] --> T2["PPO Training<br/>2M steps × 4 envs"]
        T2 --> T3["teacher_final.zip<br/><b>37D obs → 12D action</b>"]
    end

    subgraph P2["Phase 2: Data"]
        T3 --> D1["Run teacher<br/>1M+ steps"]
        D1 --> D2["Domain Randomization<br/>mass ±15%, friction ±30%<br/>obs noise, perturbations"]
        D2 --> D3["teacher_rollouts.npz<br/><b>obs_3leg (31D)<br/>action_leg3 (3D)</b>"]
    end

    subgraph P3a["Phase 3a: Supervised"]
        D3 --> S1["MLP [256,256,128]<br/>MSE loss"]
        S1 --> S2["prosthetic.onnx<br/><b>31D → 3D</b>"]
    end

    subgraph P3b["Phase 3b: RL"]
        T3 --> R1["ProstheticGo1Env<br/>teacher controls legs 0-2"]
