    end

    subgraph P4["Phase 4: Validate"]
        S2 --> V1["MSE vs teacher"]
        R3 --> V1
        V1 --> V2["Reward retention<br/>Gait symmetry<br/>Robustness"]
    end

    style P1 fill:#fef9e7,stroke:#f39c12
