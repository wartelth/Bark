graph LR
    subgraph origin["Origin Story"]
        A1["Real dog lost a leg"] --> A2["Build prosthetic<br/>with sensors"]
        A2 --> A3["Jacket with IMUs<br/><i>collect real gait data</i>"]
    end

    subgraph v1["BARK v1: Naive Approach"]
        A3 --> B1["MuJoCo Go1 env<br/><i>mask leg 3 from obs</i>"]
        B1 --> B2["PPO learns to walk<br/>+ predict missing leg"]
        B2 --> B3["BC for warm start<br/>AMP for style"]
        B3 --> B4["❌ 500K steps<br/>not enough<br/>jacket data unused"]
    end

    subgraph pivot["Architectural Pivot"]
        B4 --> C1["Realize: 2 problems<br/>mixed into 1"]
        C1 --> C2["Decompose:<br/>walking ≠ prediction"]
    end

    subgraph v2["BARK v2: Correct Approach"]
        C2 --> D1["Teacher: pre-trained<br/>4-leg walking"]
        D1 --> D2["Data: 1M+ paired<br/>(3-leg obs, leg-3 action)"]
        D2 --> D3["Student: learns<br/>only the missing leg"]
        D3 --> D4["✓ Trains in minutes<br/>✓ Perfect labels<br/>✓ Deploy ONNX"]
    end

    style origin fill:#fef9e7,stroke:#f39c12
    style v1 fill:#fde8e8,stroke:#e74c3c
    style pivot fill:#fdf2e9,stroke:#e67e22
    style v2 fill:#e8f8e8,stroke:#2ecc71
    style B4 fill:#e74c3c,color:#fff
    style D4 fill:#2ecc71,color:#fff
